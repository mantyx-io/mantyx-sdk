---
import { LinkButton } from "@astrojs/starlight/components";

interface Props {
  baseUrl: string;
}
const { baseUrl } = Astro.props;
---

<section class="w-full px-6 py-16 sm:py-24">
  <div class="mx-auto flex w-full max-w-6xl justify-center">
    <div
      class="w-full rounded-3xl border border-(--sl-color-gray-5) bg-gradient-to-br from-(--sl-color-bg-nav) to-(--sl-color-bg) px-6 py-10 text-center sm:px-12 sm:py-12"
    >
      <h2 class="m-0 text-2xl font-bold text-(--sl-color-white) sm:text-3xl">
        Ready to ship an agent?
      </h2>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <LinkButton href={`${baseUrl}docs/quickstart/`} variant="primary" icon="right-arrow">
          Read the quickstart
        </LinkButton>
        <LinkButton
          href={`${baseUrl}docs/protocol/`}
          variant="secondary"
          icon="document"
          iconPlacement="start"
        >
          Wire protocol
        </LinkButton>
      </div>
    </div>
  </div>
</section>
